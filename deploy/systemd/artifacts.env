# Example /etc/artifacts/artifacts.env — secret-bearing env vars for the
# systemd unit. Permissions must be 0600 root:artifacts (or stricter)
# since this file carries the admin token + JWT secret + AES master key.

# Process-wide admin Bearer. Generate with: openssl rand -hex 32
ARTIFACTS_ADMIN_TOKEN=

# HS256 secret used to verify Dyspel-signed JWTs. Generate with:
#   openssl rand -hex 32
ARTIFACTS_JWT_SECRET=

# Optional: pin the webhook AES-256-GCM master key (base64-encoded 32
# bytes). Leave unset to auto-generate on first run into
# <data-dir>/webhook-key.bin. Pinning here is the production move —
# rotating the env var + restarting picks up the new key.
# ARTIFACTS_WEBHOOK_KEY=

# Optional knobs (defaults shown).
# ARTIFACTS_MAX_REPOS_PER_USER=100
# ARTIFACTS_MAX_COMMIT_BLOB_BYTES=33554432    # 32 MiB
# ARTIFACTS_AUDIT_RETENTION_DAYS=90
# ARTIFACTS_SHUTDOWN_TIMEOUT_SECS=30
# ARTIFACTS_SHUTDOWN_DRAIN_DELAY_SECS=5

# Logging — same syntax as `RUST_LOG` (tracing-subscriber EnvFilter).
RUST_LOG=artifacts=info,tower_http=info
